<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ABYSSAL EXPLORER | Underwater Odyssey</title>
    <style>
        :root {
            --abyss-deep: #020617;
            --ocean-blue: #0ea5e9;
            --oxygen-color: #22d3ee;
            --hull-color: #f43f5e;
            --ui-panel: rgba(15, 23, 42, 0.85);
            --gold: #fbbf24;
        }

        body, html {
            margin: 0;
            padding: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;
            background-color: var(--abyss-deep);
            color: white;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        canvas {
            display: block;
            image-rendering: auto;
        }

        /* HUD STYLING */
        #hud {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            padding: 20px;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .hud-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }

        .stat-group {
            background: var(--ui-panel);
            padding: 15px;
            border-radius: 8px;
            border-left: 4px solid var(--ocean-blue);
            backdrop-filter: blur(10px);
            min-width: 200px;
        }

        .bar-container {
            width: 100%;
            height: 10px;
            background: #1e293b;
            border-radius: 5px;
            margin-top: 8px;
            overflow: hidden;
        }

        .bar-fill {
            height: 100%;
            width: 100%;
            transition: width 0.3s ease, background-color 0.5s;
        }

        #oxygen-fill { background: var(--oxygen-color); box-shadow: 0 0 10px var(--oxygen-color); }
        #pressure-fill { background: var(--hull-color); }

        .depth-display {
            font-size: 2rem;
            font-weight: bold;
            color: var(--ocean-blue);
            text-shadow: 0 0 15px rgba(14, 165, 233, 0.5);
        }

        /* INVENTORY & UPGRADES */
        #menu-overlay {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 80%;
            max-width: 900px;
            height: 600px;
            background: var(--ui-panel);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            display: none;
            pointer-events: auto;
            padding: 30px;
            grid-template-columns: 1fr 2fr;
            gap: 20px;
        }

        .active { display: grid !important; }

        .upgrade-card {
            background: rgba(255,255,255,0.05);
            padding: 15px;
            border-radius: 10px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: 0.2s;
            border: 1px solid transparent;
        }

        .upgrade-card:hover {
            background: rgba(255,255,255,0.1);
            border-color: var(--ocean-blue);
        }

        .upgrade-card.locked { opacity: 0.5; cursor: not-allowed; }

        #sonar-ping {
            position: absolute;
            top: 50%;
            left: 50%;
            width: 10px;
            height: 10px;
            border: 2px solid var(--ocean-blue);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            opacity: 0;
            pointer-events: none;
        }

        .ping-animate {
            animation: ping-expand 2s ease-out;
        }

        @keyframes ping-expand {
            0% { width: 0; height: 0; opacity: 1; }
            100% { width: 1000px; height: 1000px; opacity: 0; }
        }

        #credit {
            position: absolute;
            bottom: 10px;
            right: 15px;
            font-size: 0.8rem;
            color: rgba(255,255,255,0.4);
            letter-spacing: 1px;
        }
    </style>
</head>
<body>

    <canvas id="abyssCanvas"></canvas>

    <div id="sonar-ping"></div>

    <div id="hud">
        <div class="hud-top">
            <div class="stat-group">
                <div style="display:flex; justify-content:space-between">
                    <span>OXYGEN SUPPLY</span>
                    <span id="oxy-text">100%</span>
                </div>
                <div class="bar-container">
                    <div id="oxygen-fill" class="bar-fill"></div>
                </div>
                <div style="margin-top:15px; display:flex; justify-content:space-between">
                    <span>HULL INTEGRITY</span>
                    <span id="hull-text">100%</span>
                </div>
                <div class="bar-container">
                    <div id="pressure-fill" class="bar-fill"></div>
                </div>
            </div>

            <div class="depth-display">
                <span id="depth-val">0</span>m
            </div>

            <div class="stat-group" style="border-left: 4px solid var(--gold);">
                <div style="font-size: 0.8rem; color: var(--gold)">CREDITS</div>
                <div id="currency-val" style="font-size: 1.5rem; font-weight: bold;">$0</div>
            </div>
        </div>

        <div style="display: flex; justify-content: center; gap: 20px; margin-bottom: 20px;">
            <div id="notification" style="color: var(--ocean-blue); font-weight: bold;"></div>
        </div>
    </div>

    <div id="menu-overlay">
        <div>
            <h2>UPGRADES</h2>
            <div id="upgrade-list">
                </div>
        </div>
        <div style="border-left: 1px solid rgba(255,255,255,0.1); padding-left: 20px;">
            <h2>COLLECTED ARTIFACTS</h2>
            <div id="artifact-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 10px;">
                </div>
        </div>
    </div>

    <div id="credit">Made with ❤️ by kkboss/kartik</div>

<script>
/**
 * ============================================================================
 * ABYSSAL EXPLORER ENGINE
 * A high-fidelity procedural underwater simulation.
 * ============================================================================
 */

// --- 1. CORE CONSTANTS & CONFIGURATION ---
const CONFIG = {
    CHUNK_SIZE: 500,
    VIEW_DISTANCE: 1200,
    GRAVITY: 0.05,
    WATER_DRAG: 0.98,
    OXY_DRAIN_BASE: 0.01,
    MAX_DEPTH: 5000,
    BIOMES: {
        REEF: { color: '#1e40af', height: 200, roughness: 0.02 },
        TRENCH: { color: '#020617', height: 800, roughness: 0.05 },
        CAVE: { color: '#0f172a', height: 400, roughness: 0.1 }
    }
};

// --- 2. MATH & PROCEDURAL UTILITIES ---
const MathUtils = {
    lerp: (a, b, t) => a + (b - a) * t,
    clamp: (v, min, max) => Math.max(min, Math.min(max, v)),
    dist: (x1, y1, x2, y2) => Math.sqrt((x2-x1)**2 + (y2-y1)**2),
    
    // Simple Perlin-ish Noise for Terrain
    noise: (function() {
        const p = new Uint8Array(256);
        for(let i=0; i<256; i++) p[i] = i;
        for(let i=255; i>0; i--) {
            const r = Math.floor(Math.random()*(i+1));
            [p[i], p[r]] = [p[r], p[i]];
        }
        const grad = (i, x) => (i & 1 ? -x : x);
        return function(x) {
            const X = Math.floor(x) & 255;
            x -= Math.floor(x);
            const u = x * x * x * (x * (x * 6 - 15) + 10);
            return MathUtils.lerp(grad(p[X], x), grad(p[X+1], x-1), u);
        };
    })()
};

// --- 3. PARTICLE SYSTEMS ---
class Particle {
    constructor(x, y, type = 'bubble') {
        this.x = x;
        this.y = y;
        this.type = type;
        this.vx = (Math.random() - 0.5) * 1;
        this.vy = type === 'bubble' ? -Math.random() * 2 : Math.random() * 0.5;
        this.life = 1.0;
        this.size = Math.random() * 3 + 1;
    }

    update() {
        this.x += this.vx;
        this.y += this.vy;
        this.life -= 0.005;
    }

    draw(ctx, camX, camY) {
        ctx.fillStyle = this.type === 'bubble' ? `rgba(255,255,255, ${this.life * 0.4})` : `rgba(200,255,255, ${this.life * 0.2})`;
        ctx.beginPath();
        ctx.arc(this.x - camX, this.y - camY, this.size, 0, Math.PI * 2);
        ctx.fill();
    }
}

// --- 4. TERRAIN ENGINE ---
class TerrainChunk {
    constructor(index) {
        this.index = index;
        this.points = [];
        this.generate();
    }

    generate() {
        const startX = this.index * CONFIG.CHUNK_SIZE;
        for (let i = 0; i <= CONFIG.CHUNK_SIZE; i += 20) {
            const worldX = startX + i;
            const h = 600 + MathUtils.noise(worldX * 0.002) * 300 + MathUtils.noise(worldX * 0.01) * 50;
            this.points.push({ x: worldX, y: h });
        }
    }
}

// --- 5. ENTITY SYSTEM (FAUNA) ---
class SeaCreature {
    constructor(x, y, type) {
        this.x = x;
        this.y = y;
        this.type = type; // 'fish', 'shark', 'jelly'
        this.angle = Math.random() * Math.PI * 2;
        this.speed = type === 'shark' ? 3 : 1;
        this.size = type === 'shark' ? 40 : 10;
    }

    update(player) {
        // Simple AI: Wander or Chase
        this.angle += (Math.random() - 0.5) * 0.1;
        this.x += Math.cos(this.angle) * this.speed;
        this.y += Math.sin(this.angle) * this.speed;

        if (this.type === 'shark' && MathUtils.dist(this.x, this.y, player.x, player.y) < 300) {
            this.angle = Math.atan2(player.y - this.y, player.x - this.x);
        }
    }

    draw(ctx, camX, camY) {
        ctx.save();
        ctx.translate(this.x - camX, this.y - camY);
        ctx.rotate(this.angle);
        
        ctx.fillStyle = this.type === 'shark' ? '#64748b' : '#38bdf8';
        // Draw teardrop shape for fish
        ctx.beginPath();
        ctx.ellipse(0, 0, this.size, this.size/2, 0, 0, Math.PI * 2);
        ctx.fill();
        
        // Tail
        ctx.moveTo(-this.size, 0);
        ctx.lineTo(-this.size - 10, -10);
        ctx.lineTo(-this.size - 10, 10);
        ctx.fill();

        ctx.restore();
    }
}

// --- 6. PLAYER SYSTEM ---
class Player {
    constructor() {
        this.x = 250;
        this.y = 100;
        this.vx = 0;
        this.vy = 0;
        this.angle = 0;
        this.oxygen = 100;
        this.maxOxygen = 100;
        this.integrity = 100;
        this.depth = 0;
        this.credits = 0;
        this.inventory = [];
        this.upgrades = {
            tank: 1,
            fins: 1,
            hull: 1,
            sonar: 1
        };
    }

    update(keys) {
        // Movement Physics
        const accel = 0.2 * this.upgrades.fins;
        if (keys['ArrowUp'] || keys['w']) this.vy -= accel;
        if (keys['ArrowDown'] || keys['s']) this.vy += accel;
        if (keys['ArrowLeft'] || keys['a']) this.vx -= accel;
        if (keys['ArrowRight'] || keys['d']) this.vx += accel;

        this.vx *= CONFIG.WATER_DRAG;
        this.vy *= CONFIG.WATER_DRAG;
        this.x += this.vx;
        this.y += this.vy;

        if (Math.abs(this.vx) > 0.1) {
            this.angle = Math.atan2(this.vy, this.vx);
        }

        // Oxygen & Depth
        this.depth = Math.floor(this.y / 10);
        const depthPressure = Math.max(0, (this.depth - 100 * this.upgrades.hull) * 0.01);
        
        this.oxygen -= (CONFIG.OXY_DRAIN_BASE + depthPressure) / this.upgrades.tank;
        if (this.oxygen <= 0) {
            this.integrity -= 0.1;
            this.oxygen = 0;
        }

        if (this.y < 50) { // Near surface refill
            this.oxygen = Math.min(this.maxOxygen, this.oxygen + 1);
            this.integrity = Math.min(100, this.integrity + 0.05);
        }
    }

    draw(ctx, camX, camY) {
        ctx.save();
        ctx.translate(this.x - camX, this.y - camY);
        ctx.rotate(this.angle);

        // Submarine Body
        ctx.fillStyle = '#facc15';
        ctx.beginPath();
        ctx.ellipse(0, 0, 25, 15, 0, 0, Math.PI * 2);
        ctx.fill();
        ctx.strokeStyle = '#a16207';
        ctx.lineWidth = 2;
        ctx.stroke();

        // Cockpit window
        ctx.fillStyle = '#bae6fd';
        ctx.beginPath();
        ctx.arc(12, 0, 8, 0, Math.PI * 2);
        ctx.fill();

        // Propeller
        ctx.fillStyle = '#334155';
        ctx.fillRect(-28, -8, 4, 16);

        ctx.restore();
    }
}

// --- 7. THE MAIN ENGINE ---
class Engine {
    constructor() {
        this.canvas = document.getElementById('abyssCanvas');
        this.ctx = this.canvas.getContext('2d');
        this.player = new Player();
        this.chunks = new Map();
        this.particles = [];
        this.creatures = [];
        this.artifacts = [];
        this.keys = {};
        this.camera = { x: 0, y: 0 };
        this.lastPing = 0;

        this.init();
    }

    init() {
        this.resize();
        window.addEventListener('resize', () => this.resize());
        window.addEventListener('keydown', (e) => this.keys[e.key] = true);
        window.addEventListener('keyup', (e) => this.keys[e.key] = false);
        
        // Interaction
        window.addEventListener('keydown', (e) => {
            if (e.key === 'q') this.triggerSonar();
            if (e.key === 'e') this.toggleMenu();
        });

        // Spawn initial life
        for(let i=0; i<30; i++) {
            this.creatures.push(new SeaCreature(Math.random()*5000, Math.random()*2000, i % 5 === 0 ? 'shark' : 'fish'));
        }

        // Generate static artifacts
        for(let i=0; i<20; i++) {
            this.artifacts.push({
                x: Math.random() * 10000,
                y: 800 + Math.random() * 2000,
                id: i,
                collected: false,
                value: 500 + Math.floor(Math.random() * 1000)
            });
        }

        this.loop();
    }

    resize() {
        this.canvas.width = window.innerWidth;
        this.canvas.height = window.innerHeight;
    }

    triggerSonar() {
        const now = Date.now();
        if (now - this.lastPing < 3000) return;
        this.lastPing = now;

        const ping = document.getElementById('sonar-ping');
        ping.classList.remove('ping-animate');
        void ping.offsetWidth; // Trigger reflow
        ping.classList.add('ping-animate');

        // Logic: Reveal artifacts within range
        this.artifacts.forEach(art => {
            if (MathUtils.dist(this.player.x, this.player.y, art.x, art.y) < 1000) {
                this.notify("ARTIFACT DETECTED");
            }
        });
    }

    toggleMenu() {
        const menu = document.getElementById('menu-overlay');
        menu.classList.toggle('active');
        if (menu.classList.contains('active')) this.updateUpgradeUI();
    }

    updateUpgradeUI() {
        const list = document.getElementById('upgrade-list');
        list.innerHTML = '';
        const types = [
            { id: 'tank', name: 'Reinforced Oxygen Tank', cost: 1000 },
            { id: 'fins', name: 'Turbo Propellers', cost: 1500 },
            { id: 'hull', name: 'Titanium Pressure Hull', cost: 2500 }
        ];

        types.forEach(t => {
            const card = document.createElement('div');
            card.className = `upgrade-card ${this.player.credits < t.cost ? 'locked' : ''}`;
            card.innerHTML = `
                <strong>${t.name} (Lv ${this.player.upgrades[t.id]})</strong><br>
                Cost: $${t.cost}
            `;
            card.onclick = () => this.buyUpgrade(t.id, t.cost);
            list.appendChild(card);
        });
    }

    buyUpgrade(id, cost) {
        if (this.player.credits >= cost) {
            this.player.credits -= cost;
            this.player.upgrades[id]++;
            this.updateUpgradeUI();
            this.notify("UPGRADE INSTALLED");
        }
    }

    notify(text) {
        const el = document.getElementById('notification');
        el.innerText = text;
        setTimeout(() => el.innerText = '', 3000);
    }

    update() {
        this.player.update(this.keys);

        // Camera follow
        this.camera.x = MathUtils.lerp(this.camera.x, this.player.x - this.canvas.width/2, 0.1);
        this.camera.y = MathUtils.lerp(this.camera.y, this.player.y - this.canvas.height/2, 0.1);

        // Update Creatures
        this.creatures.forEach(c => c.update(this.player));

        // Chunk management
        const currentChunkIdx = Math.floor(this.player.x / CONFIG.CHUNK_SIZE);
        for (let i = currentChunkIdx - 2; i <= currentChunkIdx + 2; i++) {
            if (!this.chunks.has(i)) this.chunks.set(i, new TerrainChunk(i));
        }

        // Particle generation
        if (Math.random() > 0.8) this.particles.push(new Particle(this.player.x, this.player.y));
        this.particles.forEach((p, i) => {
            p.update();
            if (p.life <= 0) this.particles.splice(i, 1);
        });

        // Artifact Collection
        this.artifacts.forEach(art => {
            if (!art.collected && MathUtils.dist(this.player.x, this.player.y, art.x, art.y) < 50) {
                art.collected = true;
                this.player.credits += art.value;
                this.notify(`RECOVERED ANCIENT CACHE (+$${art.value})`);
            }
        });

        // UI Updates
        document.getElementById('oxygen-fill').style.width = this.player.oxygen + '%';
        document.getElementById('oxy-text').innerText = Math.floor(this.player.oxygen) + '%';
        document.getElementById('pressure-fill').style.width = this.player.integrity + '%';
        document.getElementById('hull-text').innerText = Math.floor(this.player.integrity) + '%';
        document.getElementById('depth-val').innerText = this.player.depth;
        document.getElementById('currency-val').innerText = `$${this.player.credits}`;
    }

    draw() {
        const ctx = this.ctx;
        
        // 1. Background Gradient (Depth based)
        const depthFactor = MathUtils.clamp(this.player.y / 3000, 0, 1);
        const topColor = `hsl(200, 100%, ${MathUtils.lerp(30, 2, depthFactor)}%)`;
        const botColor = `hsl(230, 100%, ${MathUtils.lerp(10, 1, depthFactor)}%)`;
        const grad = ctx.createLinearGradient(0, 0, 0, this.canvas.height);
        grad.addColorStop(0, topColor);
        grad.addColorStop(1, botColor);
        ctx.fillStyle = grad;
        ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);

        // 2. Light Shafts (God Rays)
        if (depthFactor < 0.5) {
            ctx.fillStyle = `rgba(255, 255, 255, ${0.1 * (1 - depthFactor)})`;
            for(let i=0; i<5; i++) {
                ctx.beginPath();
                ctx.moveTo(200 + i*300 - this.camera.x*0.5, 0);
                ctx.lineTo(100 + i*300 - this.camera.x*0.5, this.canvas.height);
                ctx.lineTo(400 + i*300 - this.camera.x*0.5, this.canvas.height);
                ctx.fill();
            }
        }

        // 3. Draw Terrain
        ctx.fillStyle = '#0f172a';
        ctx.beginPath();
        const activeChunks = Array.from(this.chunks.keys())
            .filter(idx => Math.abs(idx * CONFIG.CHUNK_SIZE - this.player.x) < CONFIG.VIEW_DISTANCE);
        
        activeChunks.sort((a,b) => a-b).forEach(idx => {
            const chunk = this.chunks.get(idx);
            chunk.points.forEach((p, i) => {
                if (i === 0 && idx === activeChunks[0]) ctx.moveTo(p.x - this.camera.x, p.y - this.camera.y);
                else ctx.lineTo(p.x - this.camera.x, p.y - this.camera.y);
            });
        });
        ctx.lineTo(this.canvas.width + 100, this.canvas.height + 100);
        ctx.lineTo(-100, this.canvas.height + 100);
        ctx.fill();

        // 4. Artifacts (Glow effect)
        this.artifacts.forEach(art => {
            if (art.collected) return;
            const dist = MathUtils.dist(this.player.x, this.player.y, art.x, art.y);
            if (dist < 1000) {
                ctx.fillStyle = `rgba(251, 191, 36, ${Math.sin(Date.now()*0.005) * 0.5 + 0.5})`;
                ctx.shadowBlur = 15;
                ctx.shadowColor = 'gold';
                ctx.beginPath();
                ctx.arc(art.x - this.camera.x, art.y - this.camera.y, 8, 0, Math.PI*2);
                ctx.fill();
                ctx.shadowBlur = 0;
            }
        });

        // 5. Entities & Particles
        this.particles.forEach(p => p.draw(ctx, this.camera.x, this.camera.y));
        this.creatures.forEach(c => c.draw(ctx, this.camera.x, this.camera.y));
        this.player.draw(ctx, this.camera.x, this.camera.y);
    }

    loop() {
        this.update();
        this.draw();
        requestAnimationFrame(() => this.loop());
    }
}

// Start Game
window.onload = () => new Engine();
</script>
</body>
</html>
