<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NEURAL_GLOBE // PORTFOLIO 3D</title>
    <style>
        body { margin: 0; background: #000; overflow: hidden; font-family: 'Segoe UI', sans-serif; }
        canvas { display: block; }

        /* Floating UI Panel */
        #ui-panel {
            position: absolute;
            top: 50%;
            right: 50px;
            transform: translateY(-50%);
            width: 300px;
            background: rgba(0, 20, 40, 0.8);
            backdrop-filter: blur(15px);
            border-left: 4px solid #00f2ff;
            padding: 25px;
            color: white;
            border-radius: 10px;
            box-shadow: 0 0 30px rgba(0, 242, 255, 0.2);
            opacity: 0;
            transition: all 0.5s ease;
            pointer-events: none;
            z-index: 100;
        }

        #ui-panel.active {
            opacity: 1;
            right: 80px;
            pointer-events: all;
        }

        .skill-tag {
            display: inline-block;
            background: rgba(0, 242, 255, 0.2);
            border: 1px solid #00f2ff;
            padding: 5px 10px;
            margin: 5px;
            border-radius: 4px;
            font-size: 0.8rem;
        }

        .instruction {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            color: #00f2ff;
            letter-spacing: 2px;
            text-transform: uppercase;
            font-size: 0.7rem;
            pointer-events: none;
            animation: breathe 2s infinite;
        }

        @keyframes breathe {
            0%, 100% { opacity: 0.3; }
            50% { opacity: 1; }
        }
    </style>
</head>
<body>

    <div class="instruction">Drag to rotate • Click glowing nodes</div>

    <div id="ui-panel">
        <h2 id="location-name">NODE_EXPLORATION</h2>
        <p id="location-desc">Click a hotspot on the globe to synchronize neural data.</p>
        <div id="skills-container"></div>
        <button onclick="closePanel()" style="margin-top: 20px; background: transparent; border: 1px solid white; color: white; cursor: pointer; padding: 5px 10px;">CLOSE</button>
    </div>

    <script type="importmap">
        {
          "imports": {
            "three": "https://unpkg.com/three@0.160.0/build/three.module.js",
            "three/addons/": "https://unpkg.com/three@0.160.0/examples/jsm/"
          }
        }
    </script>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';

        // --- Setup Scene ---
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        document.body.appendChild(renderer.domElement);

        // --- Lighting ---
        const ambientLight = new THREE.AmbientLight(0xffffff, 0.8);
        scene.add(ambientLight);
        const sunLight = new THREE.DirectionalLight(0xffffff, 1.5);
        sunLight.position.set(5, 3, 5);
        scene.add(sunLight);

        // --- Earth Construction ---
        const textureLoader = new THREE.TextureLoader();
        const earthGeometry = new THREE.SphereGeometry(2, 64, 64);
        const earthMaterial = new THREE.MeshPhongMaterial({
            map: textureLoader.load('https://unpkg.com/three-globe/example/img/earth-blue-marble.jpg'),
            bumpMap: textureLoader.load('https://unpkg.com/three-globe/example/img/earth-topology.png'),
            bumpScale: 0.05,
            specularMap: textureLoader.load('https://unpkg.com/three-globe/example/img/earth-water.png'),
            specular: new THREE.Color('grey')
        });
        const earth = new THREE.Mesh(earthGeometry, earthMaterial);
        scene.add(earth);

        // --- Starfield ---
        const starGeometry = new THREE.BufferGeometry();
        const starMaterial = new THREE.PointsMaterial({ color: 0xffffff });
        const starVertices = [];
        for (let i = 0; i < 10000; i++) {
            const x = (Math.random() - 0.5) * 2000;
            const y = (Math.random() - 0.5) * 2000;
            const z = (Math.random() - 0.5) * 2000;
            starVertices.push(x, y, z);
        }
        starGeometry.setAttribute('position', new THREE.Float32BufferAttribute(starVertices, 3));
        const stars = new THREE.Points(starGeometry, starMaterial);
        scene.add(stars);

        // --- Hotspots (Skills Data) ---
        const hotspots = [
            { name: "Frontend Development", lat: 40.7, lon: -74, skills: ["HTML5", "CSS3", "JavaScript", "React"] },
            { name: "Game Design", lat: 35.6, lon: 139.7, skills: ["Phaser.js", "Canvas API", "Physics Engines"] },
            { name: "Creative Coding", lat: 51.5, lon: -0.1, skills: ["Three.js", "GLSL", "SVG Animation"] }
        ];

        const hotspotGroup = new THREE.Group();
        earth.add(hotspotGroup);

        function latLonToVector3(lat, lon, radius) {
            const phi = (90 - lat) * (Math.PI / 180);
            const theta = (lon + 180) * (Math.PI / 180);
            return new THREE.Vector3(
                -radius * Math.sin(phi) * Math.cos(theta),
                radius * Math.cos(phi),
                radius * Math.sin(phi) * Math.sin(theta)
            );
        }

        hotspots.forEach(data => {
            const pos = latLonToVector3(data.lat, data.lon, 2.05);
            const geo = new THREE.SphereGeometry(0.05, 16, 16);
            const mat = new THREE.MeshBasicMaterial({ color: 0x00f2ff });
            const mesh = new THREE.Mesh(geo, mat);
            mesh.position.copy(pos);
            mesh.userData = data; // Store data in mesh
            hotspotGroup.add(mesh);
        });

        // --- Controls & Interaction ---
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        camera.position.z = 5;

        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();

        window.addEventListener('click', (event) => {
            mouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            mouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            raycaster.setFromCamera(mouse, camera);
            const intersects = raycaster.intersectObjects(hotspotGroup.children);

            if (intersects.length > 0) {
                showSkills(intersects[0].object.userData);
            }
        });

        function showSkills(data) {
            const panel = document.getElementById('ui-panel');
            const container = document.getElementById('skills-container');
            document.getElementById('location-name').innerText = data.name;
            container.innerHTML = data.skills.map(s => `<span class="skill-tag">${s}</span>`).join('');
            panel.classList.add('active');
        }

        window.closePanel = () => {
            document.getElementById('ui-panel').classList.remove('active');
        };

        // --- Animation Loop ---
        function animate() {
            requestAnimationFrame(animate);
            earth.rotation.y += 0.002; // Slow constant rotation
            controls.update();
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        animate();
    </script>
</body>
</html>
