<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Galactic Sandbox - N-Body Sim</title>
    <style>
        :root { --neon: #00f2fe; --space: #010103; --warn: #ff0055; }
        body { margin: 0; background: var(--space); color: var(--neon); font-family: 'Segoe UI', sans-serif; overflow: hidden; }
        
        #ui {
            position: absolute; top: 15px; left: 15px;
            background: rgba(0, 10, 20, 0.9);
            padding: 15px; border: 1px solid var(--neon);
            border-radius: 8px; z-index: 10; width: 240px;
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.3);
        }

        .btn-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5px; margin-bottom: 10px; }
        button {
            background: #111; color: var(--neon); border: 1px solid var(--neon);
            padding: 6px; cursor: pointer; font-size: 0.75rem; transition: 0.2s;
            text-transform: uppercase; font-weight: bold;
        }
        button:hover { background: var(--neon); color: #000; }
        button.active { background: var(--neon); color: #000; }
        button.special { border-color: #f1c40f; color: #f1c40f; }
        button.special:hover { background: #f1c40f; color: #000; }

        .slider-wrap { margin: 10px 0; font-size: 0.8rem; }
        input[type=range] { width: 100%; accent-color: var(--neon); }

        canvas { display: block; cursor: crosshair; }
        .hint { font-size: 0.7rem; color: #888; margin-top: 10px; }
        .credit { position: fixed; bottom: 10px; right: 15px; font-size: 0.7rem; color: #4facfe; opacity: 0.6; }
    </style>
</head>
<body>

<div id="ui">
    <h3 style="margin:0 0 10px 0; font-size: 0.9rem; letter-spacing: 1px;">COSMIC SANDBOX</h3>
    
    <div class="btn-grid">
        <button id="modeP" class="active">Planet</button>
        <button id="modeS">Star</button>
        <button id="modeBH">Black Hole</button>
        <button id="modeG" class="special">Galaxy</button>
    </div>
    
    <button id="modeSN" style="width:100%; border-color: var(--warn); color: var(--warn);">Supernova Tool</button>

    <div class="slider-wrap">
        Time: <span id="tw-val">1.0</span>x
        <input type="range" id="timeWarp" min="0" max="4" step="0.1" value="1">
    </div>

    <button id="reset" style="width:100%; margin-top:5px;">Reset Cosmos</button>
    
    <div class="hint">
        • Drag to Launch<br>
        • Right-Click & Drag to Pan Space<br>
        • Scroll to Zoom (Coming soon)
    </div>
</div>

<canvas id="canvas"></canvas>
<div class="credit">Made with ❤️ by kkboss/kartik</div>

<script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    
    let bodies = [];
    let mode = 'PLANET';
    let timeScale = 1;
    let isDragging = false;
    let isPanning = false;
    let startPos = {x:0, y:0}, endPos = {x:0, y:0};
    
    // Viewport Camera
    let camera = { x: 0, y: 0 };
    let lastMouse = { x: 0, y: 0 };

    const G = 2.0;

    function init() {
        canvas.width = window.innerWidth;
        canvas.height = window.innerHeight;
    }

    class Body {
        constructor(x, y, vx, vy, mass, type) {
            this.x = x; this.y = y;
            this.vx = vx; this.vy = vy;
            this.mass = mass;
            this.type = type; // PLANET, STAR, BH
            this.history = [];
            
            // Visuals based on type
            if(type === 'PLANET') { this.color = `hsl(${Math.random()*360}, 60%, 50%)`; this.r = Math.sqrt(mass)*0.8; }
            if(type === 'STAR') { this.color = '#f1c40f'; this.r = 12; }
            if(type === 'BH') { this.color = '#ff0055'; this.r = 8; }
        }

        draw() {
            const screenX = this.x + camera.x;
            const screenY = this.y + camera.y;

            // Orbit Trail
            if (this.history.length > 2) {
                ctx.beginPath();
                ctx.strokeStyle = this.color + "22";
                ctx.moveTo(this.history[0].x + camera.x, this.history[0].y + camera.y);
                this.history.forEach(p => ctx.lineTo(p.x + camera.x, p.y + camera.y));
                ctx.stroke();
            }

            // Body
            ctx.shadowBlur = this.type === 'PLANET' ? 5 : 20;
            ctx.shadowColor = this.color;
            ctx.beginPath();
            ctx.arc(screenX, screenY, this.r, 0, Math.PI*2);
            ctx.fillStyle = this.type === 'BH' ? '#000' : this.color;
            ctx.fill();
            if(this.type === 'BH' || this.type === 'STAR') {
                ctx.strokeStyle = '#fff';
                ctx.lineWidth = 1;
                ctx.stroke();
            }
            ctx.shadowBlur = 0;
        }

        update(dt) {
            this.x += this.vx * dt;
            this.y += this.vy * dt;
            this.history.push({x: this.x, y: this.y});
            if(this.history.length > 80) this.history.shift();
        }
    }

    function spawnGalaxy(cx, cy) {
        const count = 40;
        bodies.push(new Body(cx, cy, 0, 0, 50000, 'BH')); // Central BH
        for(let i=0; i<count; i++) {
            const dist = 100 + Math.random() * 300;
            const angle = Math.random() * Math.PI * 2;
            const x = cx + Math.cos(angle) * dist;
            const y = cy + Math.sin(angle) * dist;
            // Circular orbit velocity: v = sqrt(G*M/r)
            const speed = Math.sqrt((G * 50000) / dist);
            const vx = Math.cos(angle + Math.PI/2) * speed;
            const vy = Math.sin(angle + Math.PI/2) * speed;
            bodies.push(new Body(x, y, vx, vy, 10 + Math.random()*50, 'PLANET'));
        }
    }

    function supernova(cx, cy) {
        bodies.forEach(b => {
            const dx = b.x - cx;
            const dy = b.y - cy;
            const dist = Math.sqrt(dx*dx + dy*dy);
            if(dist < 300) {
                const force = (300 - dist) / 10;
                b.vx += (dx/dist) * force;
                b.vy += (dy/dist) * force;
            }
        });
    }

    function physics() {
        const dt = timeScale;
        for(let i=0; i<bodies.length; i++) {
            for(let j=0; j<bodies.length; j++) {
                if(i===j) continue;
                const b1 = bodies[i], b2 = bodies[j];
                const dx = b2.x - b1.x;
                const dy = b2.y - b1.y;
                const distSq = dx*dx + dy*dy + 100;
                const dist = Math.sqrt(distSq);
                const force = (G * b1.mass * b2.mass) / distSq;
                
                b1.vx += (dx/dist) * (force/b1.mass) * dt;
                b1.vy += (dy/dist) * (force/b1.mass) * dt;

                // Collision
                if(dist < (b1.r + b2.r) && b1.mass < b2.mass) {
                    bodies.splice(i, 1);
                    return;
                }
            }
        }
        bodies.forEach(b => b.update(dt));
    }

    function render() {
        ctx.fillStyle = '#010103';
        ctx.fillRect(0, 0, canvas.width, canvas.height);
        
        physics();
        bodies.forEach(b => b.draw());

        if(isDragging) {
            ctx.beginPath(); ctx.strokeStyle = "#fff";
            ctx.moveTo(startPos.x, startPos.y); ctx.lineTo(endPos.x, endPos.y);
            ctx.stroke();
        }
        requestAnimationFrame(render);
    }

    // Interaction
    canvas.addEventListener('mousedown', e => {
        if(e.button === 2) { isPanning = true; } 
        else {
            isDragging = true;
            startPos = {x: e.clientX, y: e.clientY};
        }
        lastMouse = {x: e.clientX, y: e.clientY};
    });

    window.addEventListener('mousemove', e => {
        if(isPanning) {
            camera.x += (e.clientX - lastMouse.x);
            camera.y += (e.clientY - lastMouse.y);
        }
        if(isDragging) endPos = {x: e.clientX, y: e.clientY};
        lastMouse = {x: e.clientX, y: e.clientY};
    });

    window.addEventListener('mouseup', e => {
        if(isPanning) { isPanning = false; return; }
        if(!isDragging) return;
        isDragging = false;
        
        const worldX = startPos.x - camera.x;
        const worldY = startPos.y - camera.y;
        const vx = (startPos.x - endPos.x) * 0.1;
        const vy = (startPos.y - endPos.y) * 0.1;

        if(mode === 'PLANET') bodies.push(new Body(worldX, worldY, vx, vy, 100, 'PLANET'));
        if(mode === 'STAR') bodies.push(new Body(worldX, worldY, vx, vy, 10000, 'STAR'));
        if(mode === 'BH') bodies.push(new Body(worldX, worldY, vx, vy, 100000, 'BH'));
        if(mode === 'GALAXY') spawnGalaxy(worldX, worldY);
        if(mode === 'SN') supernova(worldX, worldY);
    });

    // UI Logic
    const setMode = (m, id) => { 
        mode = m; 
        document.querySelectorAll('button').forEach(b => b.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    };
    document.getElementById('modeP').onclick = () => setMode('PLANET', 'modeP');
    document.getElementById('modeS').onclick = () => setMode('STAR', 'modeS');
    document.getElementById('modeBH').onclick = () => setMode('BH', 'modeBH');
    document.getElementById('modeG').onclick = () => setMode('GALAXY', 'modeG');
    document.getElementById('modeSN').onclick = () => setMode('SN', 'modeSN');
    document.getElementById('reset').onclick = () => bodies = [];
    document.getElementById('timeWarp').oninput = (e) => { 
        timeScale = e.target.value; 
        document.getElementById('tw-val').innerText = timeScale;
    };
    canvas.oncontextmenu = (e) => e.preventDefault();

    window.onresize = init;
    init(); render();
</script>
</body>
</html>
